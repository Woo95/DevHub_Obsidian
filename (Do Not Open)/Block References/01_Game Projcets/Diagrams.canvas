	"nodes":[
		{"id":"4997c3c0779d8129","type":"group","x":-4680,"y":280,"width":3660,"height":3160,"label":"게임 프레임워크 실행 흐름 설계도"},
		{"id":"abc1bfea6e953c68","type":"group","x":-3171,"y":1400,"width":1371,"height":719},
